{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "provider": {
    "ollama": {
      "models": {
        "gemma4:e2b": {
          "_launch": true,
          "name": "gemma4:e2b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "mcp": {
    "kontilo": {
      "type": "remote",
      "url": "https://kontilo.shayani.net/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secrets/kontilo-pat}"
      },
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    }
  }
}