{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "provider": {
    "ollama": {
      "models": {
        "gemma4:e2b": {
          "_launch": true,
          "name": "gemma4:e2b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "mcp": {
    "kontilo": {
      "type": "remote",
      "url": "https://kontilo.shayani.net/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secrets/kontilo-pat}"
      },
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secrets/github-pat}"
      }
    }
  }
}